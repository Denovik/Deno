# ============================================================
# CEO-GPT Arbeitsplatz, .gitignore
# Dateien und Ordner, die nie zu Git wandern sollen.
# Schützt deine Secrets, verhindert Bloat und hält das Repo sauber.
# ============================================================

# --- Credentials (kritisch, niemals committen) ---
.env
credentials/
*.pem
*.key

# --- Python ---
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# --- Daten (werden generiert, reproduzierbar aus Sammel-Scripts) ---
data/*.db
data/*.db-journal
data/*.db-shm
data/*.db-wal
data/*.log

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride

# --- IDE ---
.vscode/
.idea/

# --- Temp-Dateien ---
*.tmp
*.bak

# --- Jarvis Outputs (generierte Videos, Audio, große Dateien) ---
outputs/
backgrounds/*.mp4
backgrounds/*.mov
music/**/*.mp3
music/**/*.m4a
music/**/*.wav
music/*.mp3
music/*.m4a
music/*.wav

# --- Node (falls genutzt) ---
node_modules/
data/data.db
data/collect.log

# --- Personal OS (sensible persönliche Daten, bleiben lokal) ---
personal-os/personal.db
personal-os/personal.db-journal
personal-os/personal.db-shm
personal-os/personal.db-wal
personal-os/gesundheit-finanzen/finanzen.md
